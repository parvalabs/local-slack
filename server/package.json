{
  "name": "local-slack",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "A local Slack mock (Web API + Socket Mode + Events API) with a web UI, for testing Slack apps/bots. Not the published package - see npm/local-slack for that.",
  "keywords": [
    "slack",
    "mock",
    "testing",
    "bolt",
    "socket-mode",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parvalabs/local-slack.git",
    "directory": "server"
  },
  "bin": {
    "local-slack": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch src/cli.ts",
    "start": "bun src/cli.ts",
    "test": "bun test",
    "build:binary": "bun build --compile --minify src/cli.ts --outfile ../local-slack"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  }
}
