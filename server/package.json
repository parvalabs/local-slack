{
  "name": "local-slack",
  "version": "0.1.0",
  "type": "module",
  "description": "A local Slack mock (Web API + Socket Mode + Events API) with a web UI, for testing Slack apps/bots.",
  "keywords": ["slack", "mock", "testing", "bolt", "socket-mode", "cli"],
  "bin": {
    "local-slack": "./src/cli.ts"
  },
  "files": [
    "src",
    "public"
  ],
  "scripts": {
    "dev": "bun --watch src/cli.ts",
    "start": "bun src/cli.ts",
    "test": "bun test",
    "build:binary": "bun build --compile --minify src/cli.ts --outfile ../local-slack",
    "prepublishOnly": "cd ../web && bun install && bun run build && cd ../server && bun scripts/copy-ui.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  }
}
